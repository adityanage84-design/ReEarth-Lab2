# Lab 2 uses local tools. No paid API key is required for the LM Studio flow.

# LM Studio local OpenAI-compatible endpoint
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Open WebUI local URL after Docker starts
OPEN_WEBUI_URL=http://localhost:3000

# Placeholder key if Open WebUI asks for an API key while connecting to LM Studio
LOCAL_API_KEY=lm-studio
